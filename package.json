{
  "name": "@cap-js/cds-test",
  "version": "1.0.1",
  "description": "Test Support for CAP Node.js",
  "keywords": [
    "CAP",
    "CDS"
  ],
  "author": "SAP SE (https://www.sap.com)",
  "license": "Apache-2.0",
  "repository": {
    "url": "git+https://github.com/cap-js/cds-test.git"
  },
  "homepage": "https://cap.cloud.sap/",
  "main": "lib/cds-test.js",
  "bin": {
    "cds-test": "bin/chest.js",
    "chest": "bin/chest.js"
  },
  "files": [
    "bin/",
    "lib/",
    "index.js"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "chest": "node bin/chest.js",
    "test": "node bin/chest.js",
    "node-test:lib":  "node --test test/lib/**/*.test.js",
    "node-test:node": "node --test test/runtime/node/**/*.test.js",
    "node-test:java": "node --test --test-concurrency=1 test/runtime/java/**/*.test.js",
    "jest:lib":       "npx jest --silent --testPathPatterns=test/lib",
    "jest:node":      "npx jest --silent --testPathPatterns=test/runtime/node",
    "jest:java":      "npx jest --silent --runInBand --testPathPatterns=test/runtime/java --testTimeout=30000",
    "mocha:lib":      "npx mocha --parallel test/lib/**/*.test.js",
    "mocha:node":     "npx mocha --parallel test/runtime/node/**/*.test.js",
    "mocha:java":     "npx mocha --timeout 30000 test/runtime/java/**/*.test.js",
    "vitest:lib":     "npx vitest run --globals --silent=true test/lib",
    "vitest:node":    "npx vitest run --globals --silent=true test/runtime/node",
    "vitest:java":    "npx vitest run --globals --silent=true --no-file-parallelism --hookTimeout=30000 test/runtime/java",
    "node-test:lib:ci":  "node --test test/lib/**/*.test.js",
    "node-test:node:ci": "node --test test/runtime/node/**/*.test.js",
    "node-test:java:ci": "node --test test/runtime/java/**/*.test.js",
    "jest:lib:ci":       "npx jest --silent --testPathPatterns=test/lib",
    "jest:node:ci":      "npx jest --silent --testPathPatterns=test/runtime/node",
    "jest:java:ci":      "npx jest --silent --testPathPatterns=test/runtime/java --testTimeout=30000",
    "mocha:lib:ci":      "npx mocha --parallel test/lib/**/*.test.js",
    "mocha:node:ci":     "npx mocha --parallel test/runtime/node/**/*.test.js",
    "mocha:java:ci":     "npx mocha --parallel --timeout 30000 test/runtime/java/**/*.test.js",
    "vitest:lib:ci":     "npx vitest run --globals --silent=true test/lib",
    "vitest:node:ci":    "npx vitest run --globals --silent=true test/runtime/node",
    "vitest:java:ci":    "npx vitest run --globals --silent=true --hookTimeout=30000 test/runtime/java"
  },
  "peerDependencies": {
    "@sap/cds": ">=9.8",
    "chai-as-promised": "^8",
    "chai": "^6"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  }
}
